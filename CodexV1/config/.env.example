# Copy this file to a real .env on the target VM and fill in the required values.

# Required identity and paths
JAKE_USER=jake
JAKE_HOME=/home/jake
JAKE_DATA_DIR=/Jake-data
JAKE_REPO_DIR=/opt/JakeClaw

# REQUIRED INPUT: real git locations for the components you want installed.
OPENCLAW_REPO_URL=https://github.com/your-org/openclaw.git
OPENCLAW_REF=main
CLAW_CODE_REPO_URL=https://github.com/your-org/claw-code.git
CLAW_CODE_REF=main

# REQUIRED INPUT: OpenClaw runtime settings.
OPENCLAW_CONFIG_PATH=/Jake-data/config/openclaw-config.json
OPENCLAW_RELOAD_URL=http://127.0.0.1:3000/api/admin/reload
OPENCLAW_RELOAD_TOKEN=replace-me

# REQUIRED INPUT: Continue.dev / wrapper API.
JAKE_API_HOST=127.0.0.1
JAKE_API_PORT=8000
JAKE_API_KEY=dummy-key
LITELLM_MASTER_KEY=replace-me

# Optional external model providers. Leave blank if unused.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434

# REQUIRED INPUT: code-server security and access.
CODE_SERVER_BIND_ADDR=0.0.0.0:8080
CODE_SERVER_AUTH=password
CODE_SERVER_PASSWORD=replace-me

# REQUIRED INPUT: remote Git behavior for self-improvement.
JAKE_REPO_REMOTE=origin
JAKE_REPO_BRANCH=main

# Optional feature flags
INSTALL_DOCKER=true
INSTALL_CHROMIUM=true
INSTALL_PLAYWRIGHT=true
