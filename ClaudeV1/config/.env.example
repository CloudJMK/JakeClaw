# =============================================================================
# JakeClaw — Environment Variables Template
# Copy this file to config/.env and fill in real values.
# NEVER commit config/.env — it is in .gitignore.
#
# For production / multi-client deployments, use Doppler:
#   doppler setup && doppler run -- bash scripts/bootstrap-Jake.sh
# =============================================================================

# ─── Model / API ──────────────────────────────────────────────────────────────

# USER INPUT REQUIRED: Your Anthropic API key for OpenClaw (Claude Code)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# USER INPUT OPTIONAL: If routing LiteLLM to OpenAI instead of local claw-code
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1

# USER INPUT OPTIONAL: If routing LiteLLM to a custom OpenAI-compatible endpoint
# (e.g. local Ollama, vLLM, Together AI, etc.)
CUSTOM_MODEL_API_BASE=http://localhost:11434/v1
CUSTOM_MODEL_API_KEY=ollama   # many local providers accept any non-empty key

# ─── Jake API proxy (LiteLLM) ─────────────────────────────────────────────────

# Which backend to route to: claw-local | anthropic | openai | custom
# claw-local = routes to claw-code Axum server on CLAW_SERVER_PORT
JAKE_API_BACKEND=claw-local

# Port the claw-code Axum server listens on (internal only)
CLAW_SERVER_PORT=8081

# Port the LiteLLM proxy exposes (used by Continue.dev and OpenClaw)
JAKE_API_PORT=8000

# ─── claw-code ────────────────────────────────────────────────────────────────

# USER INPUT OPTIONAL: Override repo URL (default: ultraworkers/claw-code-parity)
CLAW_CODE_REPO=https://github.com/ultraworkers/claw-code-parity.git

# ─── JakeClaw repo ────────────────────────────────────────────────────────────

# USER INPUT REQUIRED: URL of your JakeClaw fork (used by cloud-init and self-improvement)
JAKECLAW_REPO=https://github.com/CloudJMK/JakeClaw.git

# ─── Deployment ───────────────────────────────────────────────────────────────

# Jake Linux username (must match cloud-init user-data.yaml)
JAKE_USER=jake

# Jake home directory
JAKE_HOME=/home/jake

# Persistent data volume mount point
JAKE_DATA=/Jake-data

# ─── code-server ──────────────────────────────────────────────────────────────

# USER INPUT OPTIONAL: Password for code-server web UI
# Leave blank for no-auth (acceptable on private home network per threat model)
CODE_SERVER_PASSWORD=

# Port for code-server (browser VS Code)
CODE_SERVER_PORT=8080

# ─── Proxmox (for create-Jake-vm.sh) ─────────────────────────────────────────

# USER INPUT REQUIRED if using create-Jake-vm.sh:
PROXMOX_HOST=192.168.1.10        # IP or hostname of your Proxmox host
PROXMOX_USER=root@pam            # Proxmox API user
# USER INPUT REQUIRED: Proxmox API token (preferred over password)
# Create at: Datacenter → Permissions → API Tokens
PROXMOX_TOKEN_ID=root@pam!jake-deploy
PROXMOX_TOKEN_SECRET=your-proxmox-token-secret-here

# Storage pool for VM disks
PROXMOX_STORAGE=local-lvm

# ID of the Ubuntu 24.04 cloud-init template on Proxmox
PROXMOX_TEMPLATE_ID=9000

# ─── Secrets management (optional: Doppler) ───────────────────────────────────

# USER INPUT OPTIONAL: If using Doppler, set project and config here
# DOPPLER_TOKEN=dp.st.xxxxx
# DOPPLER_PROJECT=jakeclaw
# DOPPLER_CONFIG=production
