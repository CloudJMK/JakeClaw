# =============================================================================
# JakeClaw-V2 — Environment Variables Reference
# =============================================================================
# The LIVE .env is stored ONE directory above this repo: ../.env
# Scripts source it automatically. Do NOT create a .env inside JakeClaw-V2/.
#
# Copy this file to ../.env, then fill in every value marked <REQUIRED>.
# Values marked [optional] have safe defaults; change them if needed.
# =============================================================================

# -----------------------------------------------------------------------------
# Jake User Account (inside the VM)
# -----------------------------------------------------------------------------
JAKE_USER=jake
JAKE_HOME=/home/jake
JAKE_DATA_DIR=/Jake-data           # Persistent second-disk mount point

# -----------------------------------------------------------------------------
# JakeClaw Repo (inside the VM)
# -----------------------------------------------------------------------------
JAKE_REPO_DIR=/JakeClaw
JAKECLAW_REPO=https://github.com/CloudJMK/JakeClaw    # <REQUIRED> your fork URL
JAKE_REPO_REMOTE=origin
JAKE_REPO_BRANCH=main

# -----------------------------------------------------------------------------
# Model / API Backend
# -----------------------------------------------------------------------------
# Choose one backend: claw-local | anthropic | openai | custom
JAKE_API_BACKEND=claw-local

# Anthropic (used when JAKE_API_BACKEND=anthropic, or as claw-code's provider)
ANTHROPIC_API_KEY=                 # <REQUIRED> sk-ant-...

# OpenAI (used when JAKE_API_BACKEND=openai)
OPENAI_API_KEY=                    # [optional] sk-...

# Ollama (local LLM fallback — runs on the VM itself)
OLLAMA_BASE_URL=http://localhost:11434

# OpenRouter / custom endpoint
OPENROUTER_API_KEY=                # [optional]
CUSTOM_MODEL_API_BASE=             # [optional] e.g. http://my-llm-host:8000/v1

# Model name passed to LiteLLM / Continue.dev
JAKE_MODEL_NAME=claude-sonnet-4-6

# -----------------------------------------------------------------------------
# Jake API Proxy (LiteLLM — OpenAI-compatible gateway on :8000)
# -----------------------------------------------------------------------------
JAKE_API_HOST=0.0.0.0
JAKE_API_PORT=8000
JAKE_API_KEY=jake-api-secret       # <REQUIRED> pick any strong secret
LITELLM_MASTER_KEY=sk-litellm-master-key   # <REQUIRED> separate master key

# -----------------------------------------------------------------------------
# claw-code (Jake's primary tool-use engine)
# -----------------------------------------------------------------------------
CLAW_CODE_REPO_URL=https://github.com/anthropics/claude-code
CLAW_CODE_REF=main
CLAW_SERVER_PORT=8081              # Port claw-code serves its manifest on

# -----------------------------------------------------------------------------
# OpenClaw (skill router / tool dispatcher)
# -----------------------------------------------------------------------------
OPENCLAW_REPO_URL=https://github.com/CloudJMK/openclaw
OPENCLAW_CONFIG_PATH=/JakeClaw/config/openclaw-config.json
OPENCLAW_RELOAD_URL=http://localhost:3000/admin/reload
OPENCLAW_RELOAD_TOKEN=             # <REQUIRED> pick a strong random token

# -----------------------------------------------------------------------------
# code-server (browser-based VS Code on :8080)
# -----------------------------------------------------------------------------
CODE_SERVER_BIND_ADDR=0.0.0.0:8080
CODE_SERVER_AUTH=password
CODE_SERVER_PASSWORD=              # <REQUIRED> pick a strong password

# -----------------------------------------------------------------------------
# Self-Improvement Timer
# -----------------------------------------------------------------------------
# Times (UTC hours) when the self-improvement worker runs (comma-separated)
JAKE_IMPROVE_SCHEDULE="02,08,14,20"

# -----------------------------------------------------------------------------
# Proxmox (used by create-Jake-vm.sh — run from your Proxmox host)
# -----------------------------------------------------------------------------
PROXMOX_TEMPLATE_ID=9000           # VM ID of your Ubuntu 24.04 cloud-init template
PROXMOX_STORAGE=local-lvm          # Proxmox storage pool name
PROXMOX_SNIPPETS_DIR=/var/lib/vz/snippets

# -----------------------------------------------------------------------------
# Feature Flags (set to "true" to enable)
# -----------------------------------------------------------------------------
INSTALL_DOCKER=false
INSTALL_CHROMIUM=false
INSTALL_PLAYWRIGHT=false

# -----------------------------------------------------------------------------
# Secrets Management (advanced — leave blank to use env vars directly)
# -----------------------------------------------------------------------------
# DOPPLER_TOKEN=                   # [optional] Use Doppler to inject secrets
